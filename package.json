{
  "name": "apa-chatbot",
  "private": true,
  "version": "1.6.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "typecheck:api": "tsc -p tsconfig.api.json --noEmit",
    "build": "tsc && npm run typecheck:api && vite build",
    "build:pages": "tsc && cross-env GITHUB_PAGES=true vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "check": "npm run test && npm run build && npm audit --audit-level=high"
  },
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "@types/formidable": "^3.5.1",
    "@vitejs/plugin-react": "^6.0.2",
    "formidable": "^3.5.4",
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^6.0.227",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "cross-env": "^10.1.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.9"
  }
}
